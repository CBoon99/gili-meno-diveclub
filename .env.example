# ============================================================================
# Meno Dive Club — environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ============================================================================

# --- Site -------------------------------------------------------------------
PUBLIC_SITE_URL="https://menodiveclub.com"

# --- Neon Postgres ----------------------------------------------------------
# Get from: https://console.neon.tech → your project → Connection Details
DATABASE_URL="postgresql://user:password@host.neon.tech/menodiveclub?sslmode=require"

# --- Resend (transactional email) ------------------------------------------
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
# Until DNS is verified for menodiveclub.com, use: onboarding@resend.dev
RESEND_FROM_EMAIL="bookings@menodiveclub.com"
# Where booking notifications go internally
ADMIN_NOTIFICATION_EMAIL="info@menodiveclub.com"

# --- Decap CMS (Git Gateway) ------------------------------------------------
# These are filled in via Netlify dashboard once the site is deployed.
# Listed here for visibility; not loaded by Astro at build time.
# NETLIFY_GIT_GATEWAY_ENABLED=true

# --- Optional: analytics ----------------------------------------------------
# PUBLIC_PLAUSIBLE_DOMAIN="menodiveclub.com"
