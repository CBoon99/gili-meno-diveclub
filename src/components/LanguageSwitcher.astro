---
import { switchLocale, useTranslations } from '../i18n/utils'
import type { Locale } from '../consts'

interface Props {
  lang: Locale
}
const { lang } = Astro.props
const t = useTranslations(lang)
const targetLocale: Locale = lang === 'en' ? 'fr' : 'en'
const targetHref = switchLocale(Astro.url, targetLocale)
const flag = targetLocale === 'en' ? '🇬🇧' : '🇫🇷'
---

<a
  href={targetHref}
  class="hidden items-center gap-1.5 rounded-md border border-white/15 px-3 py-1.5 text-xs font-medium text-white/80 transition hover:bg-white/10 hover:text-white sm:inline-flex"
  aria-label={`${t('lang.switchTo')} ${targetLocale === 'en' ? t('lang.en') : t('lang.fr')}`}
  rel="alternate"
  hreflang={targetLocale}
>
  <span aria-hidden="true">{flag}</span>
  <span>{targetLocale === 'en' ? 'EN' : 'FR'}</span>
</a>
