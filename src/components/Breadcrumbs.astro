---
import { breadcrumbJsonLd } from '../lib/seo'
import { SITE_CONFIG } from '../consts'

interface Props {
  items: Array<{ name: string; url: string }>
}
const { items } = Astro.props

const absoluteItems = items.map((item) => ({
  ...item,
  url: new URL(item.url, SITE_CONFIG.url).toString(),
}))
const jsonLd = breadcrumbJsonLd(absoluteItems)
---

<nav aria-label="Breadcrumb" class="text-sm text-white/60">
  <ol class="flex flex-wrap items-center gap-2">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-2">
          {i < items.length - 1 ? (
            <>
              <a href={item.url} class="link-underline hover:text-white">
                {item.name}
              </a>
              <span aria-hidden="true" class="text-white/30">
                /
              </span>
            </>
          ) : (
            <span aria-current="page" class="text-white/85">
              {item.name}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
