---
/**
 * Sea turtle drifting across the hero. Pure inline SVG + CSS — no JS, no PNG.
 * True transparent background, flippers animated as separate paths so the
 * motion feels organic.
 *
 * Three nested layers compose natural motion:
 *   1. .turtle-track  → horizontal swim across the screen (44s)
 *   2. .turtle-bob    → vertical sin wave + slight banking (8s)
 *   3. inner SVG      → flippers flap, head bobs at their own rhythms
 *
 * Disabled under prefers-reduced-motion. Hidden under 480px to avoid crowding.
 */
---

<div class="turtle-track" aria-hidden="true">
  <div class="turtle-bob">
    <svg
      class="turtle-svg"
      viewBox="0 0 240 160"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-label="A sea turtle gliding across the screen"
    >
      <defs>
        <radialGradient id="shellG" cx="35%" cy="35%" r="80%">
          <stop offset="0%" stop-color="#7d8a5e" />
          <stop offset="55%" stop-color="#4d5a3e" />
          <stop offset="100%" stop-color="#2a3526" />
        </radialGradient>
        <linearGradient id="flipG" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%" stop-color="#3f4c33" />
          <stop offset="100%" stop-color="#2a3424" />
        </linearGradient>
      </defs>

      {/* Soft drop shadow */}
      <ellipse cx="120" cy="148" rx="68" ry="6" fill="#000" opacity="0.18" />

      {/* Rear flippers — drawn first (behind) */}
      <g class="flip flip-rear-l" transform-origin="92 56">
        <path
          d="M 92 56 Q 60 36 38 36 Q 50 60 92 64 Z"
          fill="url(#flipG)"
        />
      </g>
      <g class="flip flip-rear-r" transform-origin="92 102">
        <path
          d="M 92 102 Q 60 122 38 122 Q 50 98 92 94 Z"
          fill="url(#flipG)"
        />
      </g>

      {/* Carapace (shell) */}
      <ellipse cx="118" cy="80" rx="62" ry="46" fill="url(#shellG)" />

      {/* Shell scute pattern */}
      <g fill="none" stroke="#1d2519" stroke-width="0.9" opacity="0.55">
        <path d="M 118 38 L 118 122" />
        <path d="M 78 60 Q 118 70 158 60" />
        <path d="M 78 100 Q 118 90 158 100" />
        <ellipse cx="118" cy="60" rx="16" ry="10" />
        <ellipse cx="118" cy="80" rx="18" ry="10" />
        <ellipse cx="118" cy="100" rx="16" ry="10" />
        <path d="M 88 70 Q 78 80 88 90" />
        <path d="M 148 70 Q 158 80 148 90" />
      </g>

      {/* Highlight on shell */}
      <ellipse cx="100" cy="62" rx="20" ry="12" fill="#ffffff" opacity="0.08" />

      {/* Front flippers — larger, paddle-shaped */}
      <g class="flip flip-front-l" transform-origin="158 50">
        <path
          d="M 158 50 Q 200 22 232 26 Q 222 56 168 60 Q 156 58 156 54 Z"
          fill="url(#flipG)"
        />
        <path
          d="M 175 38 Q 195 30 218 34"
          stroke="#1d2519"
          stroke-width="0.6"
          fill="none"
          opacity="0.4"
        />
      </g>
      <g class="flip flip-front-r" transform-origin="158 110">
        <path
          d="M 158 110 Q 200 138 232 134 Q 222 104 168 100 Q 156 102 156 106 Z"
          fill="url(#flipG)"
        />
        <path
          d="M 175 122 Q 195 130 218 126"
          stroke="#1d2519"
          stroke-width="0.6"
          fill="none"
          opacity="0.4"
        />
      </g>

      {/* Head */}
      <g class="head">
        <ellipse cx="190" cy="80" rx="22" ry="15" fill="#4a5a3a" />
        <path
          d="M 178 73 Q 188 70 200 73"
          stroke="#1d2519"
          stroke-width="0.6"
          fill="none"
          opacity="0.35"
        />
        <path
          d="M 178 87 Q 188 90 200 87"
          stroke="#1d2519"
          stroke-width="0.6"
          fill="none"
          opacity="0.35"
        />
        {/* eye */}
        <circle cx="200" cy="76" r="2.2" fill="#0e0e0e" />
        <circle cx="200.7" cy="75.5" r="0.7" fill="#fff" />
        {/* mouth hint */}
        <path
          d="M 207 80 Q 211 80 209 81.5"
          stroke="#1d2519"
          stroke-width="0.7"
          fill="none"
        />
      </g>
    </svg>
  </div>
</div>

<style>
  .turtle-track {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 5; /* above bg image, below text */
    overflow: hidden;
  }

  .turtle-bob {
    position: absolute;
    left: -22%;
    top: 38%;
    width: clamp(140px, 20vw, 260px);
    will-change: transform, left;
    animation:
      turtle-swim 44s linear infinite,
      turtle-bob 8s ease-in-out infinite;
  }

  .turtle-svg {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 8px 20px rgba(0, 0, 0, 0.4));
    /* Slight downward tilt so it looks like it's gliding into a current */
    transform: rotate(2deg);
  }

  /* Flipper flapping — front pair larger range, rear pair gentler */
  .flip {
    transform-box: fill-box;
  }

  .flip-front-l {
    animation: flap-front 1.8s ease-in-out infinite;
    transform-origin: 5% 100%;
  }
  .flip-front-r {
    animation: flap-front 1.8s ease-in-out infinite -0.9s;
    transform-origin: 5% 0%;
  }
  .flip-rear-l {
    animation: flap-rear 2.4s ease-in-out infinite -0.4s;
    transform-origin: 100% 100%;
  }
  .flip-rear-r {
    animation: flap-rear 2.4s ease-in-out infinite -1.2s;
    transform-origin: 100% 0%;
  }

  .head {
    transform-box: fill-box;
    transform-origin: 0% 50%;
    animation: head-bob 3s ease-in-out infinite;
  }

  /* Horizontal travel */
  @keyframes turtle-swim {
    0% { left: -22%; }
    100% { left: 122%; }
  }

  /* Vertical drift + banking rotation */
  @keyframes turtle-bob {
    0%   { transform: translateY(0)    rotate(0deg); }
    25%  { transform: translateY(-22px) rotate(-3deg); }
    50%  { transform: translateY(8px)   rotate(2deg); }
    75%  { transform: translateY(-12px) rotate(-1.5deg); }
    100% { transform: translateY(0)    rotate(0deg); }
  }

  /* Front flippers do the power stroke — bigger arc */
  @keyframes flap-front {
    0%, 100% { transform: rotate(-12deg); }
    50%      { transform: rotate(18deg); }
  }

  /* Rear flippers — smaller, more like a stabiliser */
  @keyframes flap-rear {
    0%, 100% { transform: rotate(8deg); }
    50%      { transform: rotate(-6deg); }
  }

  @keyframes head-bob {
    0%, 100% { transform: rotate(-2deg); }
    50%      { transform: rotate(3deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .turtle-bob,
    .flip,
    .head {
      animation: none !important;
    }
    .turtle-bob {
      left: 70%;
      top: 32%;
    }
  }

  /* Hide on tiny phones so the H1 has room */
  @media (max-width: 480px) {
    .turtle-track {
      display: none;
    }
  }
</style>
