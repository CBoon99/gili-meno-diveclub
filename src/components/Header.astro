---
import { useTranslations, localizedPath } from '../i18n/utils'
import LanguageSwitcher from './LanguageSwitcher.astro'
import type { Locale } from '../consts'

interface Props {
  lang: Locale
}
const { lang } = Astro.props
const t = useTranslations(lang)

const navItems = [
  { key: 'nav.about', href: '/about' },
  { key: 'nav.courses', href: '/courses' },
  { key: 'nav.diveSites', href: '/dive-sites' },
  { key: 'nav.giliMeno', href: '/regions/gili-meno' },
  { key: 'nav.diveStay', href: '/info/dive-and-stay' },
  { key: 'nav.blog', href: '/blog' },
  { key: 'nav.faq', href: '/faq' },
  { key: 'nav.contact', href: '/contact' },
] as const
---

<header
  class="fixed inset-x-0 top-0 z-40 backdrop-blur-md border-b border-white/10"
  data-header
>
  <div
    class="mx-auto flex h-16 max-w-7xl items-center justify-between gap-6 px-4 sm:px-6 lg:px-8 transition-colors"
  >
    <a
      href={localizedPath(lang, '/')}
      class="flex items-center gap-2 text-lg font-bold tracking-tight"
      aria-label="Meno Dive Club home"
    >
      <img
        src="/logo-menodiveclub.png"
        alt="Meno Dive Club logo"
        loading="eager"
        decoding="async"
        class="h-10 w-auto"
      />
      <span class="font-display">Meno&nbsp;Dive&nbsp;Club</span>
    </a>

    <nav class="hidden items-center gap-6 lg:flex" aria-label="Primary">
      {
        navItems.map((item) => (
          <a
            href={localizedPath(lang, item.href)}
            class="link-underline text-sm font-medium tracking-wide text-white/85 hover:text-white"
          >
            {t(item.key)}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <LanguageSwitcher lang={lang} />
      <a
        href={localizedPath(lang, '/booking')}
        class="rounded-full bg-ocean-500 px-4 py-2 text-sm font-semibold text-white shadow-lg shadow-ocean-500/30 transition hover:scale-[1.03] hover:bg-ocean-400"
      >
        {t('nav.book')}
      </a>
      <button
        type="button"
        class="lg:hidden rounded-md p-2 text-white/80 hover:bg-white/10"
        data-mobile-toggle
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="7" x2="20" y2="7"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="17" x2="20" y2="17"></line>
        </svg>
      </button>
    </div>
  </div>

  <nav
    class="hidden border-t border-white/10 bg-ocean-900/95 px-4 pb-6 pt-2 lg:hidden"
    data-mobile-menu
    aria-label="Mobile"
  >
    <ul class="flex flex-col gap-1">
      {
        navItems.map((item) => (
          <li>
            <a
              href={localizedPath(lang, item.href)}
              class="block rounded-md px-3 py-2 text-base font-medium text-white/85 hover:bg-white/5 hover:text-white"
            >
              {t(item.key)}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
<div class="h-16" aria-hidden="true"></div>

<script>
  const header = document.querySelector('[data-header]') as HTMLElement | null
  const toggle = document.querySelector('[data-mobile-toggle]') as HTMLButtonElement | null
  const menu = document.querySelector('[data-mobile-menu]') as HTMLElement | null

  // Translucent → solid header on scroll.
  const onScroll = () => {
    if (!header) return
    if (window.scrollY > 16) header.classList.add('bg-ocean-900/85')
    else header.classList.remove('bg-ocean-900/85')
  }
  onScroll()
  window.addEventListener('scroll', onScroll, { passive: true })

  if (toggle && menu) {
    const menuLinks = Array.from(menu.querySelectorAll('a'))

    const setMenuState = (open: boolean) => {
      menu.classList.toggle('hidden', !open)
      toggle.setAttribute('aria-expanded', String(open))
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu')
    }

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true'
      setMenuState(!isOpen)
    })

    // Keep mobile nav behavior predictable when users navigate or resize.
    menuLinks.forEach((link) => link.addEventListener('click', () => setMenuState(false)))
    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setMenuState(false)
    })
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024) setMenuState(false)
    })
  }
</script>
