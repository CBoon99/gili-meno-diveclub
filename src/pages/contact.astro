---
export const prerender = true

import BaseLayout from '@/layouts/BaseLayout.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHero from '@/components/PageHero.astro'
import { SITE_CONFIG } from '@/consts'

const lang = 'en' as const
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Contact', url: '/contact' },
]

const submitted = Astro.url.searchParams.has('success')

const contactJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Meno Dive Club',
  url: 'https://menodiveclub.com/contact',
}
---

<BaseLayout
  lang={lang}
  title="Contact Us"
  description={`Get in touch with Meno Dive Club: WhatsApp ${SITE_CONFIG.contact.phone}, email ${SITE_CONFIG.contact.email}, or our contact form.`}
  jsonLd={[contactJsonLd]}
>
  <PageHero
    image="https://images.unsplash.com/photo-1539635278303-d4002c07eae3?auto=format&fit=crop&w=2400&q=82"
    imageAlt="Underwater scene of Gili Meno reef with sunlight rays"
    eyebrow="Contact"
    title="Get in touch."
    subtitle="WhatsApp is the fastest way to reach us during the day. The form below is best for longer questions, course planning, and group bookings — we usually reply within 24 hours."
  />

  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <Breadcrumbs items={breadcrumbs} />

    <div class="mt-12 grid gap-10 lg:grid-cols-5">
      <div class="lg:col-span-2 space-y-6">
        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
          <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">WhatsApp</p>
          <a
            href={`https://wa.me/${SITE_CONFIG.contact.whatsapp}`}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-2 inline-block text-lg font-semibold text-white link-underline"
          >
            {SITE_CONFIG.contact.phone}
          </a>
          <p class="mt-1 text-sm text-white/60">Replies within an hour during business hours (08:00-18:00 WITA).</p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
          <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">Email</p>
          <a
            href={`mailto:${SITE_CONFIG.contact.email}`}
            class="mt-2 inline-block text-lg font-semibold text-white link-underline"
          >
            {SITE_CONFIG.contact.email}
          </a>
          <p class="mt-1 text-sm text-white/60">For longer messages and supporting documents.</p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
          <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">In person</p>
          <p class="mt-2 text-sm text-white/85">
            {SITE_CONFIG.location.streetAddress}<br />
            {SITE_CONFIG.location.locality}, {SITE_CONFIG.location.region}<br />
            {SITE_CONFIG.location.postalCode}, Indonesia
          </p>
          <p class="mt-3 text-sm text-white/60">
            Five-minute walk from the Gili Meno harbour. Look for the SSI flag.
          </p>
        </div>
      </div>

      <div class="lg:col-span-3">
        {
          submitted ? (
            <div class="rounded-2xl border border-emerald-400/40 bg-emerald-400/10 p-8">
              <h2 class="font-display text-2xl font-bold text-white">Message received.</h2>
              <p class="mt-2 text-white/80">
                We usually reply within a day. If you need something faster, message us
                on WhatsApp at {SITE_CONFIG.contact.phone}.
              </p>
            </div>
          ) : (
            <form
              name="contact"
              method="POST"
              data-netlify="true"
              data-netlify-honeypot="bot-field"
              action="/contact?success"
              class="space-y-5 rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur"
            >
              {/* Netlify form-detection fields */}
              <input type="hidden" name="form-name" value="contact" />
              <p class="hidden">
                <label>
                  Don't fill this out: <input name="bot-field" />
                </label>
              </p>

              <div class="grid gap-4 sm:grid-cols-2">
                <label class="block">
                  <span class="text-xs font-semibold uppercase tracking-widest text-white/60">Name</span>
                  <input
                    type="text"
                    name="name"
                    required
                    class="mt-2 block w-full rounded-lg border border-white/15 bg-ocean-900/60 px-3 py-2.5 text-white placeholder:text-white/30 focus:border-ocean-400 focus:outline-none focus:ring-2 focus:ring-ocean-400/40"
                    placeholder="Jane Doe"
                  />
                </label>

                <label class="block">
                  <span class="text-xs font-semibold uppercase tracking-widest text-white/60">Email</span>
                  <input
                    type="email"
                    name="email"
                    required
                    class="mt-2 block w-full rounded-lg border border-white/15 bg-ocean-900/60 px-3 py-2.5 text-white placeholder:text-white/30 focus:border-ocean-400 focus:outline-none focus:ring-2 focus:ring-ocean-400/40"
                    placeholder="jane@example.com"
                  />
                </label>
              </div>

              <label class="block">
                <span class="text-xs font-semibold uppercase tracking-widest text-white/60">Phone (optional)</span>
                <input
                  type="tel"
                  name="phone"
                  class="mt-2 block w-full rounded-lg border border-white/15 bg-ocean-900/60 px-3 py-2.5 text-white placeholder:text-white/30 focus:border-ocean-400 focus:outline-none focus:ring-2 focus:ring-ocean-400/40"
                  placeholder="+44 7700 900000"
                />
              </label>

              <label class="block">
                <span class="text-xs font-semibold uppercase tracking-widest text-white/60">Subject</span>
                <select
                  name="subject"
                  required
                  class="mt-2 block w-full rounded-lg border border-white/15 bg-ocean-900/60 px-3 py-2.5 text-white focus:border-ocean-400 focus:outline-none focus:ring-2 focus:ring-ocean-400/40"
                >
                  <option value="" class="bg-ocean-900">Pick one…</option>
                  <option value="course" class="bg-ocean-900">Course enquiry</option>
                  <option value="booking" class="bg-ocean-900">Booking question</option>
                  <option value="dive-stay" class="bg-ocean-900">Dive & Stay package</option>
                  <option value="group" class="bg-ocean-900">Group booking (4+ divers)</option>
                  <option value="other" class="bg-ocean-900">Something else</option>
                </select>
              </label>

              <label class="block">
                <span class="text-xs font-semibold uppercase tracking-widest text-white/60">Message</span>
                <textarea
                  name="message"
                  required
                  rows="5"
                  class="mt-2 block w-full rounded-lg border border-white/15 bg-ocean-900/60 px-3 py-2.5 text-white placeholder:text-white/30 focus:border-ocean-400 focus:outline-none focus:ring-2 focus:ring-ocean-400/40"
                  placeholder="Tell us roughly what you're after — dates, certification level, any questions."
                />
              </label>

              <button
                type="submit"
                class="inline-flex w-full items-center justify-center rounded-full bg-ocean-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-ocean-500/30 transition hover:scale-[1.02] hover:bg-ocean-400 sm:w-auto"
              >
                Send message
              </button>
              <p class="text-xs text-white/50">
                We never share your details. By submitting you agree to our <a href="/privacy" class="link-underline">privacy notice</a>.
              </p>
            </form>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>
