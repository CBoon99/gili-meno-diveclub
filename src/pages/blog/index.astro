---
export const prerender = true

import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHero from '@/components/PageHero.astro'
import { cleanSlug } from '@/lib/slug'

const lang = 'en' as const
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
)
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Bubble Diaries', url: '/blog' },
]

const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Bubble Diaries — Meno Dive Club',
  description: 'Diving stories, guides, and conservation news from Gili Meno.',
  url: 'https://menodiveclub.com/blog',
}
---

<BaseLayout
  lang={lang}
  title="Bubble Diaries — Stories from the Reefs of Gili Meno"
  description="Diving guides, conservation news, and stories from Meno Dive Club. Updated monthly."
  jsonLd={[blogJsonLd]}
>
  <PageHero
    image="https://images.unsplash.com/photo-1518837695005-2083093ee35b?auto=format&fit=crop&w=2400&q=82"
    imageAlt="A school of fish swimming over a coral reef in Indonesia"
    eyebrow="Bubble Diaries"
    title="Stories from the reefs."
    subtitle="Diving guides, conservation news, and the small things we notice while teaching on Gili Meno."
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <Breadcrumbs items={breadcrumbs} />
      <a
        href="/blog/rss.xml"
        class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-ocean-200 backdrop-blur transition hover:border-ocean-400/40 hover:bg-white/10"
        aria-label="Subscribe to Bubble Diaries RSS feed"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.18 15.64a2.18 2.18 0 1 1 0 4.36 2.18 2.18 0 0 1 0-4.36zM4 4.44A19.56 19.56 0 0 1 23.56 24h-2.83A16.73 16.73 0 0 0 4 7.27V4.44zm0 5.66a13.9 13.9 0 0 1 13.9 13.9h-2.83A11.07 11.07 0 0 0 4 12.93V10.1z"/>
        </svg>
        RSS
      </a>
    </div>

    <div class="mt-14 grid gap-10 md:grid-cols-2 lg:grid-cols-3">
      {
        posts.map((p) => {
          const slug = cleanSlug(p.id)
          return (
            <article class="group">
              {p.data.image && (
                <a
                  href={`/blog/${slug}`}
                  class="block aspect-[16/10] overflow-hidden rounded-2xl border border-white/10"
                  aria-label={`Read ${p.data.title}`}
                >
                  <img
                    src={p.data.image}
                    alt={p.data.imageAlt ?? p.data.title}
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
                  />
                </a>
              )}
              <p class="mt-4 text-xs font-medium uppercase tracking-widest text-white/50">
                <time datetime={p.data.date.toISOString()}>
                  {p.data.date.toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' })}
                </time>
                · {p.data.author}
              </p>
              <h2 class="mt-2 font-display text-2xl font-semibold text-white">
                <a href={`/blog/${slug}`} class="link-underline">
                  {p.data.title}
                </a>
              </h2>
              <p class="mt-2 text-sm leading-relaxed text-white/70">{p.data.summary}</p>
            </article>
          )
        })
      }
    </div>
  </section>
</BaseLayout>
