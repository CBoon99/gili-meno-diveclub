---
export const prerender = true

import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import AmbientCanvas from '@/components/canvas/AmbientCanvas'
import { cleanSlug } from '@/lib/slug'

const lang = 'en' as const
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
)
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Bubble Diaries', url: '/blog' },
]

const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Bubble Diaries — Meno Dive Club',
  description: 'Diving stories, guides, and conservation news from Gili Meno.',
  url: 'https://menodiveclub.com/blog',
}
---

<BaseLayout
  lang={lang}
  title="Bubble Diaries — Stories from the Reefs of Gili Meno"
  description="Diving guides, conservation news, and stories from Meno Dive Club. Updated monthly."
  jsonLd={[blogJsonLd]}
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mt-6 grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px] lg:items-start">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">Bubble diaries</p>
        <h1 class="mt-3 font-display text-4xl font-bold leading-tight tracking-tight md:text-6xl">
          Stories from the reefs.
        </h1>
        <p class="mt-6 text-lg text-white/80">
          Diving guides, conservation news, and the small things we notice while
          teaching on Gili Meno.
        </p>
      </div>
      <div
        class="hidden aspect-square overflow-hidden rounded-2xl border border-white/10 lg:block"
        aria-hidden="true"
      >
        <AmbientCanvas client:only="react" fishCount={26} bubbleCount={42} />
      </div>
    </header>

    <div class="mt-14 grid gap-10 md:grid-cols-2 lg:grid-cols-3">
      {
        posts.map((p) => {
          const slug = cleanSlug(p.id)
          return (
            <article class="group">
              {p.data.image && (
                <a
                  href={`/blog/${slug}`}
                  class="block aspect-[16/10] overflow-hidden rounded-2xl border border-white/10"
                  aria-label={`Read ${p.data.title}`}
                >
                  <img
                    src={p.data.image}
                    alt={p.data.imageAlt ?? p.data.title}
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
                  />
                </a>
              )}
              <p class="mt-4 text-xs font-medium uppercase tracking-widest text-white/50">
                <time datetime={p.data.date.toISOString()}>
                  {p.data.date.toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' })}
                </time>
                · {p.data.author}
              </p>
              <h2 class="mt-2 font-display text-2xl font-semibold text-white">
                <a href={`/blog/${slug}`} class="link-underline">
                  {p.data.title}
                </a>
              </h2>
              <p class="mt-2 text-sm leading-relaxed text-white/70">{p.data.summary}</p>
            </article>
          )
        })
      }
    </div>
  </section>
</BaseLayout>
