---
export const prerender = true

import BaseLayout from '@/layouts/BaseLayout.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import { SITE_CONFIG } from '@/consts'

const lang = 'en' as const
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Privacy', url: '/privacy' },
]
const lastUpdated = 'April 2026'
---

<BaseLayout
  lang={lang}
  title="Privacy Notice"
  description="How Meno Dive Club collects, uses, and protects your personal information. Plain-language privacy notice."
  noindex={false}
>
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mt-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">Privacy</p>
      <h1 class="mt-3 font-display text-4xl font-bold leading-tight tracking-tight md:text-5xl">
        Privacy notice
      </h1>
      <p class="mt-3 text-sm text-white/60">Last updated {lastUpdated}.</p>
    </header>

    <div
      class="prose prose-invert prose-lg mt-10 max-w-none prose-headings:font-display prose-headings:tracking-tight prose-a:text-ocean-300 hover:prose-a:text-ocean-200"
    >
      <p>
        This is a plain-language privacy notice for Meno Dive Club's website and
        booking process. We aim to collect as little as possible, store it securely,
        and never share it without a good reason.
      </p>

      <h2>What we collect</h2>
      <ul>
        <li>
          <strong>Booking information</strong> — name, email, phone, planned dates,
          experience level, dietary or medical notes if you provide them.
        </li>
        <li>
          <strong>Medical declarations</strong> — collected on a paper or PDF form
          when you arrive. Stored locally with the dive shop, not on this website.
        </li>
        <li>
          <strong>Email correspondence</strong> — anything you send us via email or
          the contact form.
        </li>
        <li>
          <strong>Photos and video</strong> — only with your explicit consent, taken
          during dives or on the boat. We'll ask you on the day.
        </li>
      </ul>
      <p>We do not run third-party advertising trackers.</p>

      <h2>How we use it</h2>
      <ul>
        <li>To respond to your enquiry.</li>
        <li>To organise your course or dive booking.</li>
        <li>To assess your fitness to dive (medical info only).</li>
        <li>To issue your SSI digital certification (where applicable).</li>
        <li>
          With your specific permission, to share photos on our social channels — we
          ask separately, every time, and you can say no.
        </li>
      </ul>

      <h2>Where it lives</h2>
      <ul>
        <li>
          <strong>Booking and contact form submissions</strong> arrive via Netlify
          Forms (server hosted in the EU/USA) and are forwarded to our staff inbox.
        </li>
        <li>
          <strong>Email correspondence</strong> is stored in our email provider's
          inbox.
        </li>
        <li>
          <strong>Certification records</strong> are stored on the SSI international
          system; we are obligated to keep them under SSI standards.
        </li>
        <li>
          <strong>Paper waivers and medical declarations</strong> are kept securely
          at the dive shop and shredded after seven years.
        </li>
      </ul>

      <h2>Cookies</h2>
      <p>
        This site sets only essential, first-party cookies needed to remember your
        language preference. We do not use analytics or marketing cookies.
      </p>

      <h2>Your rights</h2>
      <p>
        You can request a copy of any data we hold about you, ask us to correct it,
        or ask us to delete it. Email <a href={`mailto:${SITE_CONFIG.contact.email}`}
          >{SITE_CONFIG.contact.email}</a
        > with the subject line "data request" and we'll respond within 14 days.
      </p>

      <h2>Children</h2>
      <p>
        We collect data on children only with the explicit consent of a parent or
        guardian, and only what is needed to keep the child safe while diving.
      </p>

      <h2>Changes</h2>
      <p>
        If we change this notice, we'll update the date at the top and post a note on
        our home page. We'll contact you directly if any change materially affects how
        we handle your data.
      </p>

      <h2>Contact</h2>
      <p>
        Questions about this notice? Email <a href={`mailto:${SITE_CONFIG.contact.email}`}
          >{SITE_CONFIG.contact.email}</a
        > or message us on <a
          href={`https://wa.me/${SITE_CONFIG.contact.whatsapp}`}
          target="_blank"
          rel="noopener noreferrer">WhatsApp</a
        >.
      </p>
    </div>
  </article>
</BaseLayout>
