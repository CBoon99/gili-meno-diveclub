---
export const prerender = true

import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHero from '@/components/PageHero.astro'
import { cleanSlug, orderKey } from '@/lib/slug'

const lang = 'en' as const
const items = (await getCollection('info')).sort(
  (a, b) => orderKey(a.id) - orderKey(b.id),
)
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Information', url: '/info' },
]
---

<BaseLayout
  lang={lang}
  title="Practical Information"
  description="Diving safety, training approach, equipment, pricing, accommodation packages, and our Trash Hero partnership. Everything practical, in one place."
>
  <PageHero
    image="https://images.unsplash.com/photo-1591025207163-942350e47db2?auto=format&fit=crop&w=2400&q=82"
    imageAlt="Diving gear ready on the dive boat"
    eyebrow="Information"
    title="The practical bits."
    subtitle="Everything that's useful but doesn't fit on a course page: how we teach, how we keep things safe, what gear we provide, and how we work with the local conservation community."
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <Breadcrumbs items={breadcrumbs} />

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        items.map((item) => {
          const slug = cleanSlug(item.id)
          return (
            <article class="group rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur transition hover:-translate-y-1 hover:border-ocean-400/40 hover:bg-white/[0.06]">
              <h2 class="font-display text-2xl font-semibold text-white">
                <a href={`/info/${slug}`} class="link-underline">
                  {item.data.title}
                </a>
              </h2>
              <p class="mt-3 text-sm leading-relaxed text-white/70">{item.data.summary}</p>
              <a
                href={`/info/${slug}`}
                class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-ocean-300 group-hover:text-ocean-200"
              >
                Read more
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
              </a>
            </article>
          )
        })
      }
    </div>
  </section>
</BaseLayout>
