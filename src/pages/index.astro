---
export const prerender = true

import BaseLayout from '../layouts/BaseLayout.astro'
import { useTranslations } from '../i18n/utils'

const lang = 'en' as const
const t = useTranslations(lang)
---

<BaseLayout
  lang={lang}
  title="Meno Dive Club — SSI Dive Centre, Gili Meno"
  description="Dive Gili Meno with a small, family-run SSI school. Beginner courses to advanced certifications, world-class reefs, and turtles on every dive."
>
  <!-- Hero (3D scene placeholder — wired up in Phase 3) -->
  <section
    class="relative isolate flex min-h-[100svh] items-end overflow-hidden bg-gradient-to-b from-ocean-900 via-ocean-800 to-ocean-700 pb-20"
  >
    <div
      aria-hidden="true"
      class="absolute inset-0 -z-10 opacity-50"
      data-hero-canvas-mount
    >
      <!-- React Three Fiber hero scene mounts here in Phase 3 -->
    </div>
    <div
      aria-hidden="true"
      class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_30%_30%,rgba(10,173,219,0.25),transparent_55%),radial-gradient(circle_at_70%_70%,rgba(212,165,116,0.15),transparent_60%)]"
    >
    </div>

    <div class="mx-auto grid w-full max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-12 lg:px-8">
      <div class="lg:col-span-7" style="animation: var(--animate-fade-up);">
        <p class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-3 py-1 text-xs font-medium uppercase tracking-widest text-ocean-200">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-ocean-400"></span>
          SSI Certified · Gili Meno · Indonesia
        </p>
        <h1 class="font-display text-5xl font-extrabold leading-[0.95] tracking-tight sm:text-6xl lg:text-7xl">
          {t('hero.title')}
        </h1>
        <p class="mt-6 max-w-xl text-lg text-white/80">{t('hero.subtitle')}</p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href="/booking"
            class="rounded-full bg-ocean-500 px-6 py-3 text-sm font-semibold text-white shadow-xl shadow-ocean-500/30 transition hover:scale-[1.03] hover:bg-ocean-400"
          >
            {t('hero.cta')}
          </a>
          <a
            href="/courses"
            class="rounded-full border border-white/20 bg-white/5 px-6 py-3 text-sm font-semibold text-white/90 backdrop-blur transition hover:bg-white/10"
          >
            {t('hero.secondary')}
          </a>
        </div>
      </div>
    </div>

    <!-- Bubble accents (CSS-only, no JS, respects reduced-motion) -->
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
      <span class="absolute left-[12%] bottom-0 block h-3 w-3 rounded-full bg-white/40 blur-[1px]" style="animation: var(--animate-bubble); animation-delay: 0s;"></span>
      <span class="absolute left-[28%] bottom-0 block h-2 w-2 rounded-full bg-white/30 blur-[1px]" style="animation: var(--animate-bubble); animation-delay: 1.2s;"></span>
      <span class="absolute left-[55%] bottom-0 block h-4 w-4 rounded-full bg-white/30 blur-[1px]" style="animation: var(--animate-bubble); animation-delay: 2.4s;"></span>
      <span class="absolute left-[72%] bottom-0 block h-2.5 w-2.5 rounded-full bg-white/35 blur-[1px]" style="animation: var(--animate-bubble); animation-delay: 3.6s;"></span>
      <span class="absolute left-[88%] bottom-0 block h-1.5 w-1.5 rounded-full bg-white/40 blur-[1px]" style="animation: var(--animate-bubble); animation-delay: 4.8s;"></span>
    </div>
  </section>

  <!-- About teaser -->
  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="grid gap-10 md:grid-cols-2 md:items-center">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">{t('nav.about')}</p>
        <h2 class="mt-3 font-display text-3xl font-bold leading-tight tracking-tight md:text-5xl">
          {t('home.aboutHeading')}
        </h2>
      </div>
      <p class="text-lg leading-relaxed text-white/80">{t('home.aboutBody')}</p>
    </div>
  </section>

  <!-- Phase 1 placeholder grid — replaced with real content in Phases 2-6 -->
  <section class="mx-auto max-w-7xl px-4 pb-32 sm:px-6 lg:px-8">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        ['Beginner Courses', 'Fun Dives', 'SSI Certifications', 'Eco-Scuba', 'Dive & Stay', 'Refresher'].map(
          (course) => (
            <article class="group relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur transition hover:-translate-y-1 hover:border-ocean-400/40 hover:bg-white/[0.06]">
              <h3 class="font-display text-2xl font-semibold text-white">{course}</h3>
              <p class="mt-2 text-sm text-white/70">Real content arrives in Phase 2.</p>
              <span class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-ocean-300">
                Learn more
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
              </span>
            </article>
          ),
        )
      }
    </div>
  </section>
</BaseLayout>
