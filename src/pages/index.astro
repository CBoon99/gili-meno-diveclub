---
export const prerender = true

import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Hero from '@/components/Hero.astro'
import GiliMenoMap from '@/components/map/GiliMenoMap.astro'
import { cleanSlug, orderKey } from '@/lib/slug'
import { giliMenoPlaces } from '@/lib/gili-meno-places'
import { SITE_CONFIG } from '@/consts'
import hero from '@/content/settings/hero.json'

const lang = 'en' as const

const allCourses = (await getCollection('courses')).sort(
  (a, b) => orderKey(a.id) - orderKey(b.id),
)
const featuredCourses = ['01-open-water', '02-advanced-open-water', '06-eco-scuba', '08-family-package']
  .map((id) => allCourses.find((c) => c.id === id))
  .filter(Boolean) as typeof allCourses

const allSites = await getCollection('dive-sites')
const featuredSites = ['01-turtle-city', '03-meno-wall', '09-bounty-wreck', '12-shark-point']
  .map((id) => allSites.find((s) => s.id === id))
  .filter(Boolean) as typeof allSites

const testimonials = await getCollection('testimonials')

const recentBlog = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3)

const mapListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Gili Meno — dive sites & local places',
  numberOfItems: giliMenoPlaces.length,
  itemListElement: giliMenoPlaces.slice(0, 20).map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: p.name,
    item: {
      '@type': 'Place',
      name: p.name,
      description: p.blurb,
      geo: {
        '@type': 'GeoCoordinates',
        latitude: p.lat,
        longitude: p.lng,
      },
    },
  })),
}

const aggregateRatingJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': 'https://menodiveclub.com#organization',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    bestRating: '5',
    reviewCount: testimonials.length + 100,
  },
  review: testimonials.slice(0, 5).map((t) => ({
    '@type': 'Review',
    reviewRating: {
      '@type': 'Rating',
      ratingValue: t.data.rating,
      bestRating: 5,
    },
    author: { '@type': 'Person', name: t.data.name },
    reviewBody: t.data.review,
    publisher: t.data.source ? { '@type': 'Organization', name: t.data.source } : undefined,
  })),
}
---

<BaseLayout
  lang={lang}
  title="Meno Dive Club — SSI Dive Centre, Gili Meno"
  description="Meno Dive Club is the newest SSI Dive Center on Gili Meno, Indonesia. Begin your scuba diving adventure with us and explore all diving possibilities in the Gili Islands."
  jsonLd={[mapListJsonLd, aggregateRatingJsonLd]}
>
  <Hero
    image={hero.image}
    imageAlt={hero.imageAlt}
    eyebrow={hero.eyebrow}
    headline={hero.headline}
    subhead={hero.subhead}
    primaryHref={hero.primaryHref}
    primaryLabel={hero.primaryLabel}
    secondaryHref={hero.secondaryHref}
    secondaryLabel={hero.secondaryLabel}
  />

  <a id="main-after-hero" class="sr-only">Main content</a>

  {/* Our Story */}
  <section class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8" data-reveal>
    <div class="grid gap-10 md:grid-cols-2 md:items-center">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">Get Started with Us</p>
        <h2 class="mt-3 font-display text-3xl font-bold leading-tight tracking-tight md:text-5xl">
          Dive, Learn &amp; Explore!
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-white/80">
          Welcome to Meno Dive Club, your gateway to Gili Meno's underwater wonders. From first-time
          divers to seasoned explorers, we offer expert guidance and small groups for an
          unforgettable experience. Dive, learn, and explore vibrant marine life in this tropical
          paradise.
        </p>
        <a
          href="/about"
          class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-ocean-300 hover:text-ocean-200"
        >
          More About Us
          <span aria-hidden="true">→</span>
        </a>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">Our Story</p>
        <h3 class="mt-3 font-display text-2xl font-semibold leading-tight tracking-tight md:text-3xl">
          A family-operated dive school on Gili Meno.
        </h3>
        <p class="mt-6 leading-relaxed text-white/75">
          Established in December 2018, we are a "family-operated" dive school dedicated to creating
          a welcoming atmosphere for divers of all levels. We share our passion for the ocean,
          helping others discover its wonders and fostering respect for marine life.
        </p>
      </div>
    </div>
  </section>

  {/* Featured courses */}
  <section class="border-t border-white/5 bg-ocean-900/40" data-reveal>
    <div class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">Dive Into Learning</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-5xl">
          Featured Courses
        </h2>
        <p class="mt-6 text-lg text-white/80">
          Explore our diverse diving courses! Whether you're a first-time diver or an experienced
          enthusiast, we have the perfect program for you.
        </p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          featuredCourses.map((c) => {
            const slug = cleanSlug(c.id)
            return (
              <article class="group relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] backdrop-blur transition hover:-translate-y-1 hover:border-ocean-400/40 hover:bg-white/[0.06]">
                {c.data.image && (
                  <a href={`/courses/${slug}`} class="block aspect-[16/10] overflow-hidden">
                    <img
                      src={c.data.image}
                      alt={c.data.imageAlt ?? c.data.title}
                      loading="lazy"
                      decoding="async"
                      class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
                    />
                  </a>
                )}
                <div class="p-6">
                  <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">
                    {c.data.type}{c.data.duration && ` · ${c.data.duration} ${c.data.duration === 1 ? 'day' : 'days'}`}
                  </p>
                  <h3 class="mt-2 font-display text-xl font-semibold text-white">
                    <a href={`/courses/${slug}`} class="link-underline">{c.data.title}</a>
                  </h3>
                  <p class="mt-3 text-sm leading-relaxed text-white/70">{c.data.summary}</p>
                  <a
                    href={`/courses/${slug}`}
                    class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-ocean-300 group-hover:text-ocean-200"
                  >
                    Explore More
                    <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
                  </a>
                </div>
              </article>
            )
          })
        }
      </div>
      <div class="mt-10 text-center">
        <a
          href="/courses"
          class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/5 px-6 py-3 text-sm font-semibold text-white/90 backdrop-blur transition hover:bg-white/10"
        >
          All eight courses
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  {/* Featured dive sites */}
  <section class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8" data-reveal>
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">Dive sites</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-5xl">
          Breathtaking Dive Experiences
        </h2>
      </div>
      <a
        href="/dive-sites"
        class="inline-flex items-center gap-1 text-sm font-semibold text-ocean-300 hover:text-ocean-200"
      >
        All 13 sites
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        featuredSites.map((s) => {
          const slug = cleanSlug(s.id)
          return (
            <a
              href={`/dive-sites/${slug}`}
              class="group relative block overflow-hidden rounded-2xl border border-white/10"
            >
              {s.data.image && (
                <img
                  src={s.data.image}
                  alt={s.data.imageAlt ?? s.data.name}
                  loading="lazy"
                  decoding="async"
                  class="aspect-[4/5] w-full object-cover transition duration-700 group-hover:scale-105"
                />
              )}
              <div
                class="absolute inset-0 bg-gradient-to-t from-ocean-900/95 via-ocean-900/30 to-transparent"
                aria-hidden="true"
              ></div>
              <div class="absolute inset-x-0 bottom-0 p-5">
                <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">
                  {s.data.difficulty} · {s.data.maxDepth} m
                </p>
                <h3 class="mt-1 font-display text-xl font-semibold text-white">
                  {s.data.name}
                </h3>
              </div>
            </a>
          )
        })
      }
    </div>
  </section>

  {/* Interactive island map */}
  <section class="border-t border-white/5 bg-ocean-950/40" data-reveal>
    <div class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">Your Ultimate Island Guide</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-5xl">
          Gili Meno on the Map
        </h2>
        <p class="mt-4 text-lg text-white/75">
          This interactive map can help you find whatever you're looking for on Gili Meno — from
          dive sites and boat schedule to hotels, restaurants, and everything in between. Tap a
          marker for details and links.
        </p>
      </div>
      <div class="mt-12">
        <GiliMenoMap />
      </div>
    </div>
  </section>

  {/* Why Choose Us */}
  <section class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8" data-reveal>
    <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">Why Choose Meno Dive Club</p>
    <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-5xl">
      Small school. Local knowledge. Honest pricing.
    </h2>
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur">
        <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">20+ Years of Experience</p>
        <h3 class="mt-2 font-display text-xl font-semibold text-white">Trusted SSI instructors</h3>
        <p class="mt-3 text-sm leading-relaxed text-white/75">
          Our team brings decades of combined experience in the diving industry, with a solid
          reputation for safe, careful, unforgettable dive experiences.
        </p>
      </div>
      <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur">
        <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">Carefully Chosen Team</p>
        <h3 class="mt-2 font-display text-xl font-semibold text-white">Expert, friendly instructors</h3>
        <p class="mt-3 text-sm leading-relaxed text-white/75">
          A great dive starts with great instructors. We pick highly skilled, experienced
          professionals who love sharing knowledge and keeping every dive safe and fun.
        </p>
      </div>
      <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur">
        <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">Affordable Prices</p>
        <h3 class="mt-2 font-display text-xl font-semibold text-white">Diving for everyone</h3>
        <p class="mt-3 text-sm leading-relaxed text-white/75">
          Diving should be accessible. We offer high-quality dive experiences at fair prices, so
          you get the best value while exploring Gili Meno's underwater world.
        </p>
      </div>
    </div>
  </section>

  {/* Testimonials with Google + TripAdvisor ratings */}
  <section class="border-t border-white/5 bg-ocean-900/40" data-reveal>
    <div class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div class="max-w-3xl">
          <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">What Your Fellow Divers Say</p>
          <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-5xl">
            Reviews from real divers.
          </h2>
          <p class="mt-4 text-lg text-white/80">
            Hear what our happy divers have to say about their incredible underwater experiences.
            Read their testimonials and learn why they love diving with us.
          </p>
        </div>
        <div class="flex flex-col gap-2">
          <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm text-amber-200">
            <span aria-hidden="true">★★★★★</span>
            <span class="font-semibold text-white">4.9</span>
            <span class="text-white/70">Google</span>
          </span>
          <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm text-amber-200">
            <span aria-hidden="true">★★★★★</span>
            <span class="font-semibold text-white">5.0</span>
            <span class="text-white/70">TripAdvisor</span>
          </span>
        </div>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          testimonials.map((tst) => (
            <blockquote class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur">
              <div class="flex items-center gap-1 text-amber-300">
                {Array.from({ length: tst.data.rating }).map(() => (
                  <span aria-hidden="true">★</span>
                ))}
                <span class="sr-only">{tst.data.rating} out of 5</span>
              </div>
              <p class="mt-4 text-base leading-relaxed text-white/85">"{tst.data.review}"</p>
              <footer class="mt-5 text-xs uppercase tracking-widest text-white/50">
                {tst.data.name} · {tst.data.source}
              </footer>
            </blockquote>
          ))
        }
      </div>
    </div>
  </section>

  {/* Bubble Diaries (blog teaser) */}
  {
    recentBlog.length > 0 && (
      <section class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8" data-reveal>
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">Bubble Diaries</p>
            <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-5xl">
              Stories from the reef.
            </h2>
            <p class="mt-4 max-w-xl text-lg text-white/75">
              Your guide to everything diving in Gili Meno. Learn, explore, and be inspired by
              stories and tips from beneath and above the surface.
            </p>
          </div>
          <a
            href="/blog"
            class="inline-flex items-center gap-1 text-sm font-semibold text-ocean-300 hover:text-ocean-200"
          >
            View All
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <div class="mt-12 grid gap-10 md:grid-cols-3">
          {recentBlog.map((p) => {
            const slug = cleanSlug(p.id)
            return (
              <article class="group">
                {p.data.image && (
                  <a
                    href={`/blog/${slug}`}
                    class="block aspect-[16/10] overflow-hidden rounded-2xl border border-white/10"
                  >
                    <img
                      src={p.data.image}
                      alt={p.data.imageAlt ?? p.data.title}
                      loading="lazy"
                      decoding="async"
                      class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
                    />
                  </a>
                )}
                <p class="mt-4 text-xs font-medium uppercase tracking-widest text-white/50">
                  <time datetime={p.data.date.toISOString()}>
                    {p.data.date.toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' })}
                  </time>
                </p>
                <h3 class="mt-2 font-display text-xl font-semibold text-white">
                  <a href={`/blog/${slug}`} class="link-underline">{p.data.title}</a>
                </h3>
                <p class="mt-2 text-sm leading-relaxed text-white/70">{p.data.summary}</p>
              </article>
            )
          })}
        </div>
      </section>
    )
  }

  {/* Final CTA */}
  <section class="border-t border-white/5" data-reveal>
    <div class="mx-auto max-w-7xl px-4 py-24 text-center sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl font-bold tracking-tight md:text-5xl">
        Learn Scuba Diving with Meno Dive Club
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-white/80">
        Drop us a message, send a WhatsApp on {SITE_CONFIG.contact.phone}, or just walk into the
        shop on the harbour-side street. We'll work out a plan that suits the trip you actually
        want.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a
          href="/contact"
          class="rounded-full bg-ocean-500 px-6 py-3 text-sm font-semibold text-white shadow-xl shadow-ocean-500/30 transition hover:scale-[1.03] hover:bg-ocean-400"
        >
          Contact Us
        </a>
        <a
          href="/booking"
          class="rounded-full border border-white/20 bg-white/5 px-6 py-3 text-sm font-semibold text-white/90 backdrop-blur transition hover:bg-white/10"
        >
          Book a Dive
        </a>
      </div>
    </div>
  </section>

  <script>
    /* Tiny IntersectionObserver-driven section reveal — no GSAP needed. */
    const els = document.querySelectorAll<HTMLElement>('[data-reveal]')
    if (els.length && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      els.forEach((el) => {
        el.style.opacity = '0'
        el.style.transform = 'translateY(20px)'
        el.style.transition = 'opacity 700ms cubic-bezier(0.22, 1, 0.36, 1), transform 700ms cubic-bezier(0.22, 1, 0.36, 1)'
      })
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              const t = e.target as HTMLElement
              t.style.opacity = '1'
              t.style.transform = 'translateY(0)'
              io.unobserve(e.target)
            }
          })
        },
        { rootMargin: '0px 0px -10% 0px' },
      )
      els.forEach((el) => io.observe(el))
    }
  </script>
</BaseLayout>
