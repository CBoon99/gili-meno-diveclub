---
export const prerender = true

import { getCollection, render } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import { cleanSlug } from '@/lib/slug'

export async function getStaticPaths() {
  const items = await getCollection('marine-life')
  return items.map((entry) => ({
    params: { slug: cleanSlug(entry.id) },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content } = await render(entry)
const lang = 'en' as const

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Marine life', url: '/marine-life' },
  { name: entry.data.title, url: `/marine-life/${cleanSlug(entry.id)}` },
]
---

<BaseLayout
  lang={lang}
  title={entry.data.title}
  description={entry.data.summary}
  image={entry.data.image}
>
  <article class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mt-6">
      <h1 class="font-display text-4xl font-bold leading-tight tracking-tight md:text-6xl">
        {entry.data.title}
      </h1>
      <p class="mt-4 text-lg text-white/80">{entry.data.summary}</p>
    </header>

    {
      entry.data.image && (
        <figure class="mt-10 overflow-hidden rounded-2xl border border-white/10">
          <img
            src={entry.data.image}
            alt={entry.data.imageAlt ?? entry.data.title}
            loading="eager"
            decoding="async"
            class="aspect-[16/9] w-full object-cover"
          />
        </figure>
      )
    }

    <div
      class="prose prose-invert prose-lg mt-10 max-w-none prose-headings:font-display prose-headings:tracking-tight prose-a:text-ocean-300 hover:prose-a:text-ocean-200"
    >
      <Content />
    </div>

    {
      (entry.data.species || entry.data.bestSites) && (
        <aside class="mt-12 grid gap-6 rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur sm:grid-cols-2">
          {entry.data.species && (
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">Species</p>
              <ul class="mt-3 space-y-1 text-sm text-white/85">
                {entry.data.species.map((s) => (
                  <li>· {s}</li>
                ))}
              </ul>
            </div>
          )}
          {entry.data.bestSites && (
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">Best sites</p>
              <ul class="mt-3 space-y-1 text-sm text-white/85">
                {entry.data.bestSites.map((s) => (
                  <li>· {s}</li>
                ))}
              </ul>
            </div>
          )}
        </aside>
      )
    }
  </article>
</BaseLayout>
