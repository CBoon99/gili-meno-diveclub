---
export const prerender = true

import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHero from '@/components/PageHero.astro'
import { cleanSlug, orderKey } from '@/lib/slug'

const lang = 'en' as const
const regions = (await getCollection('regions')).sort(
  (a, b) => orderKey(a.id) - orderKey(b.id),
)
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Regions', url: '/regions' },
]
---

<BaseLayout
  lang={lang}
  title="Diving Indonesia — Regions We Cover"
  description="Diving guides for Gili Meno, Gili Air, Gili Trawangan, Lombok, Bali, and Komodo. Where to base, what to expect, and how to plan a multi-region trip."
>
  <PageHero
    image="https://images.unsplash.com/photo-1602002418082-a4443e081dd1?auto=format&fit=crop&w=2400&q=82"
    imageAlt="Calm tropical waters of the Gili Islands seen from a dive boat"
    eyebrow="Regions"
    title="Diving the Lombok strait — and beyond."
    subtitle="We're based on Gili Meno, but the wider region has plenty to offer divers coming through. Quick guides to each region we know well."
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <Breadcrumbs items={breadcrumbs} />

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        regions.map((r) => {
          const slug = cleanSlug(r.id)
          return (
            <article class="group relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] backdrop-blur transition hover:-translate-y-1 hover:border-ocean-400/40 hover:bg-white/[0.06]">
              {r.data.image && (
                <a href={`/regions/${slug}`} class="block aspect-[16/10] overflow-hidden">
                  <img
                    src={r.data.image}
                    alt={r.data.imageAlt ?? r.data.title}
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
                  />
                </a>
              )}
              <div class="p-6">
                <h2 class="font-display text-2xl font-semibold text-white">
                  <a href={`/regions/${slug}`} class="link-underline">
                    {r.data.title}
                  </a>
                </h2>
                {r.data.description && (
                  <p class="mt-3 text-sm leading-relaxed text-white/70">{r.data.description}</p>
                )}
                <a
                  href={`/regions/${slug}`}
                  class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-ocean-300 group-hover:text-ocean-200"
                >
                  Region guide
                  <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
                </a>
              </div>
            </article>
          )
        })
      }
    </div>
  </section>
</BaseLayout>
