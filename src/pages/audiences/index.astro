---
export const prerender = true

import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHero from '@/components/PageHero.astro'
import { cleanSlug, orderKey } from '@/lib/slug'

const lang = 'en' as const
const items = (await getCollection('audiences')).sort(
  (a, b) => orderKey(a.id) - orderKey(b.id),
)
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Who we teach', url: '/audiences' },
]
---

<BaseLayout
  lang={lang}
  title="Who We Teach"
  description="Family divers, solo travellers, divers on a certification journey, and eco-conscious divers — how Meno Dive Club fits each."
>
  <PageHero
    image="https://images.unsplash.com/photo-1561485132-59468cd0b553?auto=format&fit=crop&w=2400&q=82"
    imageAlt="A family enjoying time by the ocean in Indonesia"
    eyebrow="Who we teach"
    title="Diving for everyone."
    subtitle="Family-friendly courses, solo-traveler-friendly logistics, structured certification journeys, and conservation-aware diving for divers who want their footprint to matter."
  />

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <Breadcrumbs items={breadcrumbs} />

    <div class="mt-14 grid gap-6 sm:grid-cols-2">
      {
        items.map((item) => {
          const slug = cleanSlug(item.id)
          return (
            <article class="group relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] backdrop-blur transition hover:-translate-y-1 hover:border-ocean-400/40 hover:bg-white/[0.06]">
              {item.data.image && (
                <a href={`/audiences/${slug}`} class="block aspect-[16/10] overflow-hidden">
                  <img
                    src={item.data.image}
                    alt={item.data.imageAlt ?? item.data.title}
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
                  />
                </a>
              )}
              <div class="p-6">
                <h2 class="font-display text-2xl font-semibold text-white">
                  <a href={`/audiences/${slug}`} class="link-underline">
                    {item.data.title}
                  </a>
                </h2>
                <p class="mt-3 text-sm leading-relaxed text-white/70">{item.data.summary}</p>
              </div>
            </article>
          )
        })
      }
    </div>
  </section>
</BaseLayout>
