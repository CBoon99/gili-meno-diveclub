---
export const prerender = true

import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import { cleanSlug, orderKey } from '@/lib/slug'

const lang = 'en' as const
const items = (await getCollection('audiences')).sort(
  (a, b) => orderKey(a.id) - orderKey(b.id),
)
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Who we teach', url: '/audiences' },
]
---

<BaseLayout
  lang={lang}
  title="Who We Teach"
  description="Family divers, solo travellers, divers on a certification journey, and eco-conscious divers — how Meno Dive Club fits each."
>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mt-6 max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">Who we teach</p>
      <h1 class="mt-3 font-display text-4xl font-bold leading-tight tracking-tight md:text-6xl">
        Diving for everyone.
      </h1>
      <p class="mt-6 text-lg text-white/80">
        Family-friendly courses, solo-traveler-friendly logistics, structured
        certification journeys, and conservation-aware diving for divers who want
        their footprint to matter.
      </p>
    </header>

    <div class="mt-14 grid gap-6 sm:grid-cols-2">
      {
        items.map((item) => {
          const slug = cleanSlug(item.id)
          return (
            <article class="group relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] backdrop-blur transition hover:-translate-y-1 hover:border-ocean-400/40 hover:bg-white/[0.06]">
              {item.data.image && (
                <a href={`/audiences/${slug}`} class="block aspect-[16/10] overflow-hidden">
                  <img
                    src={item.data.image}
                    alt={item.data.imageAlt ?? item.data.title}
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
                  />
                </a>
              )}
              <div class="p-6">
                <h2 class="font-display text-2xl font-semibold text-white">
                  <a href={`/audiences/${slug}`} class="link-underline">
                    {item.data.title}
                  </a>
                </h2>
                <p class="mt-3 text-sm leading-relaxed text-white/70">{item.data.summary}</p>
              </div>
            </article>
          )
        })
      }
    </div>
  </section>
</BaseLayout>
