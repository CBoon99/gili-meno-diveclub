---
export const prerender = true

import BaseLayout from '@/layouts/BaseLayout.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import CoralScene from '@/components/canvas/CoralScene'
import { SITE_CONFIG } from '@/consts'

const lang = 'en' as const
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Book', url: '/booking' },
]

const submitted = Astro.url.searchParams.has('success')

const reserveActionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Meno Dive Club booking',
  provider: {
    '@type': 'Organization',
    name: 'Meno Dive Club',
  },
  areaServed: 'Gili Meno, Indonesia',
  potentialAction: {
    '@type': 'ReserveAction',
    target: 'https://menodiveclub.com/booking',
  },
}
---

<BaseLayout
  lang={lang}
  title="Book a Dive or Course"
  description="Book a dive course or fun-dive day at Meno Dive Club, Gili Meno. We'll confirm by email within a day and reply with payment instructions."
  jsonLd={[reserveActionJsonLd]}
>
  <section class="relative mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
    <div
      class="pointer-events-none absolute inset-0 -z-10 hidden opacity-60 lg:block [&_canvas]:h-full [&_canvas]:w-full"
      aria-hidden="true"
    >
      <CoralScene client:only="react" />
    </div>
    <Breadcrumbs items={breadcrumbs} />

    <header class="mt-6">
      <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">Book</p>
      <h1 class="mt-3 font-display text-4xl font-bold leading-tight tracking-tight md:text-6xl">
        Book your dive.
      </h1>
      <p class="mt-6 text-lg text-white/80">
        Tell us what you'd like to do and when. We'll come back within a day with
        availability, payment details, and any questions about your level or
        plans. No deposit yet — that comes after we confirm.
      </p>
    </header>

    {
      submitted ? (
        <div class="mt-10 rounded-2xl border border-emerald-400/40 bg-emerald-400/10 p-8">
          <h2 class="font-display text-2xl font-bold text-white">Booking request received.</h2>
          <p class="mt-2 text-white/80">
            We'll reply by email within 24 hours with availability and payment
            instructions. If you need something faster, WhatsApp us at {SITE_CONFIG.contact.phone}.
          </p>
        </div>
      ) : (
        <form
          name="booking"
          method="POST"
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          action="/booking?success"
          class="mt-10 space-y-5 rounded-2xl border border-white/10 bg-white/[0.03] p-6 backdrop-blur"
        >
          <input type="hidden" name="form-name" value="booking" />
          <p class="hidden">
            <label>
              Don't fill this out: <input name="bot-field" />
            </label>
          </p>

          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block">
              <span class="text-xs font-semibold uppercase tracking-widest text-white/60">Name</span>
              <input
                type="text"
                name="name"
                required
                class="mt-2 block w-full rounded-lg border border-white/15 bg-ocean-900/60 px-3 py-2.5 text-white placeholder:text-white/30 focus:border-ocean-400 focus:outline-none focus:ring-2 focus:ring-ocean-400/40"
                placeholder="Jane Doe"
              />
            </label>

            <label class="block">
              <span class="text-xs font-semibold uppercase tracking-widest text-white/60">Email</span>
              <input
                type="email"
                name="email"
                required
                class="mt-2 block w-full rounded-lg border border-white/15 bg-ocean-900/60 px-3 py-2.5 text-white placeholder:text-white/30 focus:border-ocean-400 focus:outline-none focus:ring-2 focus:ring-ocean-400/40"
                placeholder="jane@example.com"
              />
            </label>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block">
              <span class="text-xs font-semibold uppercase tracking-widest text-white/60">Phone / WhatsApp</span>
              <input
                type="tel"
                name="phone"
                class="mt-2 block w-full rounded-lg border border-white/15 bg-ocean-900/60 px-3 py-2.5 text-white placeholder:text-white/30 focus:border-ocean-400 focus:outline-none focus:ring-2 focus:ring-ocean-400/40"
                placeholder="+44 7700 900000"
              />
            </label>

            <label class="block">
              <span class="text-xs font-semibold uppercase tracking-widest text-white/60">Number of divers</span>
              <input
                type="number"
                name="divers"
                min="1"
                max="20"
                value="1"
                required
                class="mt-2 block w-full rounded-lg border border-white/15 bg-ocean-900/60 px-3 py-2.5 text-white focus:border-ocean-400 focus:outline-none focus:ring-2 focus:ring-ocean-400/40"
              />
            </label>
          </div>

          <label class="block">
            <span class="text-xs font-semibold uppercase tracking-widest text-white/60">What do you want to book?</span>
            <select
              name="course"
              required
              class="mt-2 block w-full rounded-lg border border-white/15 bg-ocean-900/60 px-3 py-2.5 text-white focus:border-ocean-400 focus:outline-none focus:ring-2 focus:ring-ocean-400/40"
            >
              <option value="" class="bg-ocean-900">Pick one…</option>
              <option value="open-water" class="bg-ocean-900">SSI Open Water Diver (3-4 days)</option>
              <option value="advanced" class="bg-ocean-900">SSI Advanced Adventurer (2 days)</option>
              <option value="rescue" class="bg-ocean-900">SSI Stress & Rescue (3-4 days)</option>
              <option value="divemaster" class="bg-ocean-900">SSI Divemaster (14+ days)</option>
              <option value="specialty" class="bg-ocean-900">SSI Specialty (1-2 days)</option>
              <option value="eco-scuba" class="bg-ocean-900">Eco-Scuba Diver Programme (2 days)</option>
              <option value="refresher" class="bg-ocean-900">Scuba Skills Update / Refresher</option>
              <option value="family" class="bg-ocean-900">Family Diving Package</option>
              <option value="fun-dive" class="bg-ocean-900">Fun dive(s) — already certified</option>
              <option value="dive-stay" class="bg-ocean-900">Dive & Stay package</option>
              <option value="not-sure" class="bg-ocean-900">Not sure yet — talk to me</option>
            </select>
          </label>

          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block">
              <span class="text-xs font-semibold uppercase tracking-widest text-white/60">Preferred start date</span>
              <input
                type="date"
                name="date"
                required
                class="mt-2 block w-full rounded-lg border border-white/15 bg-ocean-900/60 px-3 py-2.5 text-white focus:border-ocean-400 focus:outline-none focus:ring-2 focus:ring-ocean-400/40"
              />
            </label>

            <label class="block">
              <span class="text-xs font-semibold uppercase tracking-widest text-white/60">Existing certification</span>
              <select
                name="certification"
                class="mt-2 block w-full rounded-lg border border-white/15 bg-ocean-900/60 px-3 py-2.5 text-white focus:border-ocean-400 focus:outline-none focus:ring-2 focus:ring-ocean-400/40"
              >
                <option value="none" class="bg-ocean-900">None — I'm new to diving</option>
                <option value="open-water" class="bg-ocean-900">Open Water (any agency)</option>
                <option value="advanced" class="bg-ocean-900">Advanced (any agency)</option>
                <option value="rescue" class="bg-ocean-900">Rescue (any agency)</option>
                <option value="divemaster-plus" class="bg-ocean-900">Divemaster or above</option>
              </select>
            </label>
          </div>

          <label class="block">
            <span class="text-xs font-semibold uppercase tracking-widest text-white/60">Anything else we should know?</span>
            <textarea
              name="notes"
              rows="4"
              class="mt-2 block w-full rounded-lg border border-white/15 bg-ocean-900/60 px-3 py-2.5 text-white placeholder:text-white/30 focus:border-ocean-400 focus:outline-none focus:ring-2 focus:ring-ocean-400/40"
              placeholder="Special requests, accommodation needs, kids' ages, medical conditions, etc."
            />
          </label>

          <label class="flex items-start gap-3 text-sm text-white/75">
            <input
              type="checkbox"
              name="consent"
              required
              class="mt-0.5 h-4 w-4 rounded border-white/30 bg-ocean-900/60 text-ocean-500 focus:ring-2 focus:ring-ocean-400/40"
            />
            <span>
              I understand Meno Dive Club will email me to confirm availability and
              payment details before any deposit is taken. (See our
              <a href="/privacy" class="link-underline text-ocean-300">privacy notice</a>.)
            </span>
          </label>

          <button
            type="submit"
            class="inline-flex w-full items-center justify-center rounded-full bg-ocean-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-ocean-500/30 transition hover:scale-[1.02] hover:bg-ocean-400 sm:w-auto"
          >
            Send booking request
          </button>
        </form>
      )
    }
  </section>
</BaseLayout>
