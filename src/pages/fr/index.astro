---
export const prerender = true

import BaseLayout from '../../layouts/BaseLayout.astro'
import { useTranslations } from '../../i18n/utils'

const lang = 'fr' as const
const t = useTranslations(lang)
---

<BaseLayout
  lang={lang}
  title="Meno Dive Club — Centre de plongée SSI, Gili Meno"
  description="Plongée à Gili Meno avec une école SSI familiale. Cours débutants jusqu'aux certifications avancées, récifs de classe mondiale et tortues à chaque plongée."
>
  <section
    class="relative isolate flex min-h-[100svh] items-end overflow-hidden bg-gradient-to-b from-ocean-900 via-ocean-800 to-ocean-700 pb-20"
  >
    <div aria-hidden="true" class="absolute inset-0 -z-10 opacity-50" data-hero-canvas-mount></div>
    <div
      aria-hidden="true"
      class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_30%_30%,rgba(10,173,219,0.25),transparent_55%),radial-gradient(circle_at_70%_70%,rgba(212,165,116,0.15),transparent_60%)]"
    >
    </div>

    <div class="mx-auto grid w-full max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-12 lg:px-8">
      <div class="lg:col-span-7" style="animation: var(--animate-fade-up);">
        <p class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-3 py-1 text-xs font-medium uppercase tracking-widest text-ocean-200">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-ocean-400"></span>
          Certifié SSI · Gili Meno · Indonésie
        </p>
        <h1 class="font-display text-5xl font-extrabold leading-[0.95] tracking-tight sm:text-6xl lg:text-7xl">
          {t('hero.title')}
        </h1>
        <p class="mt-6 max-w-xl text-lg text-white/80">{t('hero.subtitle')}</p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href="/fr/booking"
            class="rounded-full bg-ocean-500 px-6 py-3 text-sm font-semibold text-white shadow-xl shadow-ocean-500/30 transition hover:scale-[1.03] hover:bg-ocean-400"
          >
            {t('hero.cta')}
          </a>
          <a
            href="/fr/courses"
            class="rounded-full border border-white/20 bg-white/5 px-6 py-3 text-sm font-semibold text-white/90 backdrop-blur transition hover:bg-white/10"
          >
            {t('hero.secondary')}
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="grid gap-10 md:grid-cols-2 md:items-center">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-ocean-300">{t('nav.about')}</p>
        <h2 class="mt-3 font-display text-3xl font-bold leading-tight tracking-tight md:text-5xl">
          {t('home.aboutHeading')}
        </h2>
      </div>
      <p class="text-lg leading-relaxed text-white/80">{t('home.aboutBody')}</p>
    </div>
  </section>
</BaseLayout>
