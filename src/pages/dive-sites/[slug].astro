---
export const prerender = true

import { getCollection, render } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import { cleanSlug } from '@/lib/slug'

export async function getStaticPaths() {
  const sites = await getCollection('dive-sites')
  return sites.map((entry) => ({
    params: { slug: cleanSlug(entry.id) },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content } = await render(entry)
const lang = 'en' as const

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Dive sites', url: '/dive-sites' },
  { name: entry.data.name, url: `/dive-sites/${cleanSlug(entry.id)}` },
]

const placeJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TouristAttraction',
  name: entry.data.name,
  description: `Dive site near Gili Meno, max depth ${entry.data.maxDepth}m, ${entry.data.difficulty.toLowerCase()} level.`,
  geo: {
    '@type': 'GeoCoordinates',
    latitude: entry.data.lat,
    longitude: entry.data.lng,
  },
  containedInPlace: {
    '@type': 'Place',
    name: 'Gili Meno, Indonesia',
  },
  image: entry.data.image,
}
---

<BaseLayout
  lang={lang}
  title={`${entry.data.name} — Dive Site, Gili Meno`}
  description={`${entry.data.name} dive site on Gili Meno. Max depth ${entry.data.maxDepth}m, ${entry.data.difficulty.toLowerCase()} level. Marine life, conditions, best months.`}
  image={entry.data.image}
  imageAlt={entry.data.imageAlt ?? `${entry.data.name} dive site on Gili Meno`}
  jsonLd={[placeJsonLd]}
>
  <article class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mt-6">
      <h1 class="font-display text-4xl font-bold leading-tight tracking-tight md:text-6xl">
        {entry.data.name}
      </h1>
      <div class="mt-4 flex flex-wrap items-center gap-3 text-sm">
        <span class="inline-flex items-center rounded-full border border-white/15 bg-white/5 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-white/80">
          {entry.data.difficulty}
        </span>
        <span class="text-white/60">Max depth {entry.data.maxDepth} m</span>
        <span class="text-white/30" aria-hidden="true">·</span>
        <span class="text-white/60">
          {entry.data.lat.toFixed(4)}, {entry.data.lng.toFixed(4)}
        </span>
      </div>
    </header>

    {
      entry.data.image && (
        <figure class="mt-10 overflow-hidden rounded-2xl border border-white/10">
          <img
            src={entry.data.image}
            alt={entry.data.imageAlt ?? entry.data.name}
            loading="eager"
            decoding="async"
            class="aspect-[16/9] w-full object-cover"
          />
        </figure>
      )
    }

    <div
      class="prose prose-invert prose-lg mt-10 max-w-none prose-headings:font-display prose-headings:tracking-tight prose-a:text-ocean-300 hover:prose-a:text-ocean-200"
    >
      <Content />
    </div>

    <div class="mt-10 flex flex-wrap gap-3">
      <a
        href="/booking"
        class="rounded-full bg-ocean-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-ocean-500/30 transition hover:scale-[1.03] hover:bg-ocean-400"
      >
        Book a dive here
      </a>
      <a
        href="/dive-sites"
        class="rounded-full border border-white/20 bg-white/5 px-6 py-3 text-sm font-semibold text-white/90 transition hover:bg-white/10"
      >
        See all 13 sites
      </a>
    </div>
  </article>
</BaseLayout>
