---
import '../styles/global.css'
import { SITE_CONFIG, type Locale } from '../consts'
import { localBusinessJsonLd, organizationJsonLd, websiteJsonLd } from '../lib/seo'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import WhatsAppButton from '../components/WhatsAppButton.astro'

interface Props {
  title: string
  description: string
  image?: string
  imageAlt?: string
  noindex?: boolean
  type?: 'website' | 'article'
  lang: Locale
  /** Optional <head> JSON-LD blocks beyond the default LocalBusiness, Organization, WebSite. */
  jsonLd?: Record<string, unknown>[]
  /** ISO 8601 date string — set on article pages for `article:published_time`. */
  publishedTime?: string
  modifiedTime?: string
  /** Comma-separated extra keywords — appended to defaults. */
  keywords?: string
}

const {
  title,
  description,
  image = '/og-default.jpg',
  imageAlt = 'Meno Dive Club — SSI Dive Centre on Gili Meno, Indonesia',
  noindex = false,
  type = 'website',
  lang,
  jsonLd = [],
  publishedTime,
  modifiedTime,
  keywords,
} = Astro.props

const baseKeywords = [
  'Meno Dive Club',
  'Gili Meno diving',
  'SSI Dive Centre',
  'Lombok diving',
  'Gili Islands scuba',
  'turtle diving Gili Meno',
  'Open Water course Indonesia',
  'Eco-Scuba',
  'Bubble Diaries',
]
const allKeywords = keywords ? [...baseKeywords, keywords].join(', ') : baseKeywords.join(', ')

const canonical = new URL(Astro.url.pathname, SITE_CONFIG.url).toString()
const ogImageUrl = new URL(image, SITE_CONFIG.url).toString()
const fullTitle = title === SITE_CONFIG.name ? title : `${title} · ${SITE_CONFIG.name}`

// hreflang alternates: same path under each locale
const path = Astro.url.pathname.replace(/^\/(en|fr)/, '') || '/'
const alternates: Record<Locale, string> = {
  en: new URL(path === '/' ? '/' : path, SITE_CONFIG.url).toString(),
  fr: new URL(`/fr${path === '/' ? '' : path}`, SITE_CONFIG.url).toString(),
}

const allJsonLd = [localBusinessJsonLd(), organizationJsonLd(), websiteJsonLd(), ...jsonLd]
---

<!doctype html>
<html lang={lang} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content={SITE_CONFIG.colors.oceanDeep} />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={allKeywords} />
    <meta name="author" content={SITE_CONFIG.name} />
    <meta name="publisher" content={SITE_CONFIG.name} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
    <meta name="googlebot" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <meta name="format-detection" content="telephone=yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content={SITE_CONFIG.shortName} />
    <meta name="application-name" content={SITE_CONFIG.name} />
    <meta name="msapplication-TileColor" content={SITE_CONFIG.colors.oceanDeep} />
    <meta name="color-scheme" content="dark" />
    <meta http-equiv="content-language" content={lang} />
    <meta name="geo.region" content="ID-NB" />
    <meta name="geo.placename" content="Gili Meno, Lombok" />
    <meta name="geo.position" content={`${SITE_CONFIG.location.coordinates.lat};${SITE_CONFIG.location.coordinates.lng}`} />
    <meta name="ICBM" content={`${SITE_CONFIG.location.coordinates.lat}, ${SITE_CONFIG.location.coordinates.lng}`} />

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={alternates.en} />
    <link rel="alternate" hreflang="fr" href={alternates.fr} />
    <link rel="alternate" hreflang="x-default" href={alternates.en} />

    <!-- Favicons & PWA -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/icon-32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/icon-16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/favicon.svg" color={SITE_CONFIG.colors.oceanLight} />
    <link rel="manifest" href="/manifest.webmanifest" />

    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,800&display=swap"
    />

    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:site_name" content={SITE_CONFIG.name} />
    <meta property="og:locale" content={lang === 'en' ? 'en_AU' : 'fr_FR'} />
    <meta property="og:locale:alternate" content={lang === 'en' ? 'fr_FR' : 'en_AU'} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />

    {
      allJsonLd.map((data) => (
        <script type="application/ld+json" set:html={JSON.stringify(data)} />
      ))
    }
  </head>
  <body class="bg-ocean-900 text-white antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:rounded focus:bg-ocean-500 focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to content
    </a>

    <Header lang={lang} />

    <main id="main">
      <slot />
    </main>

    <Footer lang={lang} />
    <WhatsAppButton />
  </body>
</html>
